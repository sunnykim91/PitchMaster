{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- ':(exclude)docs' ':(exclude)*.md' ':(exclude)scripts' ':(exclude)public/screenshots' ':(exclude)public/screenshot' ':(exclude)public/cardscreenshot' ':(exclude)public/duelsscreenshot' ':(exclude)public/newscreenshot' ':(exclude).claude' ':(exclude).serena' ':(exclude).agents' ':(exclude)e2e' ':(exclude)src/__tests__' ':(exclude).github' ':(exclude)v0' ':(exclude)v0card' ':(exclude)public/styles' ':(exclude)public/*.png'",
  "crons": [
    {
      "path": "/api/cron/vote-reminder",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/push/invite-nudge",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/dues-reminder",
      "schedule": "0 0 1,15 * *"
    },
    {
      "path": "/api/cron/match-nudge",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/push/match-nudge",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/match-result",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/match-completed-push",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/role-guide-push",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/no-vote-penalty",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/exemption-expiry",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/hard-delete-withdrawn",
      "schedule": "0 3 * * *"
    }
  ]
}
