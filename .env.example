# PitchMaster 환경변수 예시
# 실제 값을 채워 `.env.local` 로 복사해 사용하세요. (.env* 파일은 절대 커밋 금지)
# NEXT_PUBLIC_* 는 브라우저로 노출되는 공개 키, 나머지는 서버 전용 비밀 키입니다.

# ── Supabase (필수) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용 service_role 키 — 절대 클라이언트 노출 금지

# ── 카카오 OAuth (필수) ────────────────────────────
KAKAO_CLIENT_ID=                    # REST API 키
KAKAO_CLIENT_SECRET=
NEXT_PUBLIC_KAKAO_JS_KEY=           # 카카오 JS SDK (공유하기)

# ── 세션 / 인증 (필수) ─────────────────────────────
SESSION_SECRET=                     # HMAC-SHA256 세션 서명 키 (충분히 긴 랜덤 문자열)
NEXTAUTH_URL=http://localhost:3000  # 앱 base URL (배포 시 https://pitch-master.app)

# ── AI 기능 (전술 코치·풀플랜·경기 요약) ──────────
ANTHROPIC_API_KEY=

# ── OCR (네이버 클로바 — 회비 영수증 인식) ─────────
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET_KEY=

# ── Web Push (VAPID) ───────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# ── 네이티브 푸시 (Firebase FCM) ───────────────────
# 둘 중 하나만 설정 (B64 = 서비스계정 JSON을 base64 인코딩한 값)
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_B64=

# ── 날씨 (경기 일정 날씨 표시) ─────────────────────
OPENWEATHERMAP_API_KEY=

# ── 분석 (GA4 Measurement Protocol) ────────────────
GA4_API_SECRET=

# ── Cron 보호 (Vercel cron 호출 인증) ──────────────
CRON_SECRET=

# ── 개발 전용 (선택) ───────────────────────────────
# DEV_IMPERSONATE=                  # 로컬에서 특정 사용자로 가장 (개발 한정)
# NEXT_PUBLIC_COMMIT_HASH=          # 빌드 시 자동 주입 (Vercel: VERCEL_GIT_COMMIT_SHA)
